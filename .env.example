# =============================================================================
# Observer v1.0.0 - Environment Configuration
# =============================================================================
#
# USAGE:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your database password
#   3. Run: python main.py
#
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL) — REQUIRED
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://observer:CHANGEME@localhost:5432/observer

# Maximum signals in memory (lower = less RAM usage)
MAX_SIGNALS_LIMIT=25000

# =============================================================================
# TRANSLATION (NLLB-200 via CTranslate2)
# =============================================================================
# Model is auto-downloaded during setup (python setup_observer.py).
# To install manually: python scripts/download_nllb.py

# Translation mode: 'nllb' (recommended) or 'off' (disabled)
AI_TRANSLATOR_MODE=nllb

# Device: 'cpu' (recommended for field use), 'cuda' (GPU), or 'auto'
NLLB_DEVICE=cpu

# Compute type: 'int8' (CPU-friendly, recommended), 'float16' (GPU), 'auto'
NLLB_COMPUTE_TYPE=int8

# Threading
NLLB_INTER_THREADS=1
NLLB_INTRA_THREADS=4

# Generation parameters
NLLB_BEAM_SIZE=4
NLLB_LENGTH_PENALTY=1.1
NLLB_REPETITION_PENALTY=1.1
NLLB_NO_REPEAT_NGRAM=3

# Batching
NLLB_BATCH_SIZE=256
NLLB_BATCH_TYPE=tokens
NLLB_MAX_LENGTH=512
NLLB_MAX_INPUT_LENGTH=512

# =============================================================================
# RSS FEED COLLECTION
# =============================================================================

# Enable RSS feed collection
FEED_COLLECTION_ENABLED=true

# Feed check interval (seconds between collection cycles)
FEED_CHECK_INTERVAL=300

# Feed sources are stored in PostgreSQL (feed_sources table).
# On first run, Observer auto-seeds 3,500+ feeds from data/feed_sources_seed.csv.
# Manage feeds via the admin console at /dev.

# Maximum articles to collect per feed per cycle
FEED_MAX_ARTICLES_PER_SOURCE=5

# Max concurrent feed fetches
FEED_CONCURRENCY=10

# Collector timeout (seconds)
COLLECTOR_TIMEOUT=2800

# Default filter mode
DEFAULT_FILTER_MODE=from_within

# =============================================================================
# CONTENT FILTERING
# =============================================================================

# Enable content relevance filtering
CONTENT_FILTER_ENABLED=true

# Filter mode: whitelist | blacklist | both
CONTENT_FILTER_MODE=both

# Active filter files (filenames without path, in data/filters/)
CONTENT_FILTER_WL=WL_geopolitical
CONTENT_FILTER_BL=BL_default

# Log rejected articles (verbose, debugging only)
CONTENT_FILTER_LOG_REJECTED=false

# =============================================================================
# ENTITY SCREENING (OpenSanctions — local CSV matching)
# =============================================================================
# Downloads sanctions data as CSV (~65MB) and matches locally via pg_trgm.
# No external services required for matching.

SANCTIONS_NET_ENABLED=true

# FBI Most Wanted API (requires internet)
FBI_ENABLED=false

# Interpol Notices API (requires internet)
INTERPOL_ENABLED=false

# =============================================================================
# WEB SCRAPER (trafilatura — on-demand article fetching)
# =============================================================================

SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_DELAY_BETWEEN_ARTICLES=2.0
SCRAPER_MAX_ARTICLES_PER_SITE=20
SCRAPER_MIN_WORD_COUNT=100
SCRAPER_FAST_MODE=true

# =============================================================================
# SERVER
# =============================================================================

# Host binding (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS — Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000

# =============================================================================
# SECURITY (Optional)
# =============================================================================

# API Keys — comma-separated list. When set, all endpoints require auth.
# Generate: python -c "from api.security import generate_api_key; print(generate_api_key())"
# OBSERVER_API_KEYS=observer_your_key_here

# =============================================================================
# LOGGING
# =============================================================================
# DEBUG=true for verbose output during troubleshooting

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
#
# QUICK START:
#   1. Set DATABASE_URL with your PostgreSQL password
#   2. Run: python main.py
#   3. Open: http://localhost:8000
#
# =============================================================================
